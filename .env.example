# All variables below are REQUIRED and validated at startup (see apps/api/src/env.ts).
# There are no defaults: a missing or malformed value aborts boot with a clear error.

# One of: development | production | test
NODE_ENV=development

# pino log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=debug

# TCP port for the API server (1-65535)
PORT=3001

# postgres:// or postgresql:// connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nano_url

# redis:// or rediss:// connection string
REDIS_URL=redis://localhost:6379

# Secret used to sign JWTs. Must be at least 32 characters and must NOT be the
# example placeholder. Generate one with: openssl rand -hex 32
JWT_SECRET=replace-with-a-random-string-at-least-32-chars-long

# Used by docker-compose only (not validated by the API)
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=change-me
