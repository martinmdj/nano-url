{
  "name": "@nano-url/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit && esbuild src/index.ts src/migrate.ts --bundle --platform=node --format=esm --target=node20 --packages=external --outdir=dist",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@nano-url/shared": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.33.0",
    "hono": "^4.4.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.24.0",
    "esbuild": "^0.18.20",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0"
  }
}
